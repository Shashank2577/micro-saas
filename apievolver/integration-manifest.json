{
  "app": "apievolver",
  "displayName": "APIEvolver",
  "version": "0.0.1",
  "baseUrl": "https://api-apievolver.YOURDOMAIN.com",
  "emits": [
    "apievolver.breaking-change.detected",
    "apievolver.version.published",
    "apievolver.sdk.generated"
  ],
  "consumes": [
    "apimanager.version.published",
    "dependencyradar.scan.completed",
    "securitypulse.finding.created"
  ],
  "capabilities": [
    {
      "name": "diff-specs",
      "input": "oldSpec+newSpec",
      "output": "diffReport"
    },
    {
      "name": "detect-breaking",
      "input": "specDiff",
      "output": "breakingChanges[]"
    },
    {
      "name": "notify-consumers",
      "input": "serviceId+change",
      "output": "notificationStatus"
    }
  ],
  "healthEndpoint": "/actuator/health"
}
