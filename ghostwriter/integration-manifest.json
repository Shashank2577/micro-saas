{
  "appName": "ghostwriter",
  "version": "1.0.0",
  "api": {
    "endpoints": [
      {
        "path": "/api/documents",
        "method": "GET",
        "description": "Get all documents"
      },
      {
        "path": "/api/documents/{id}",
        "method": "GET",
        "description": "Get document by id"
      },
      {
        "path": "/api/documents",
        "method": "POST",
        "description": "Create document"
      },
      {
        "path": "/api/projects",
        "method": "GET",
        "description": "Get all projects"
      },
      {
        "path": "/api/templates",
        "method": "GET",
        "description": "Get all templates"
      },
      {
        "path": "/api/personas",
        "method": "GET",
        "description": "Get all personas"
      },
      {
        "path": "/api/generate",
        "method": "POST",
        "description": "Generate AI content"
      }
    ]
  },
  "webhooks": {
    "emitted": [
      "document.created",
      "document.updated",
      "content_request.completed"
    ],
    "consumed": []
  }
}
