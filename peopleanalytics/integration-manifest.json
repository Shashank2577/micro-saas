{
  "app": "peopleanalytics",
  "displayName": "PeopleAnalytics",
  "version": "0.0.1",
  "baseUrl": "https://api-peopleanalytics.YOURDOMAIN.com",
  "emits": [
    "MetricAggregationCompleted",
    "EngagementScoringCompleted",
    "RetentionPredictionCompleted",
