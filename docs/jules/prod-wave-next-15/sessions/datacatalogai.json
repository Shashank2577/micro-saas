{
  "app_id": "datacatalogai",
  "title": "DataCatalogAI",
  "domain": "Data Governance",
  "intent": "Data asset catalog with ownership, lineage context, and semantic enrichment",
  "maturity": {
    "score": 60,
    "tier": "Beta",
    "depth": "Deep",
    "risks": [
      "no-backend-tests",
      "no-frontend-tests",
      "no-backend-dockerfile",
      "no-readme"
    ]
  },
  "modules": [
    "assets",
    "ownership",
    "lineage",
    "tags",
    "policies",
    "discovery"
  ],
  "entities": [
    "DataAsset",
    "OwnershipRecord",
    "LineageRef",
    "SemanticTag",
    "PolicyBinding",
    "DiscoveryQuery"
  ],
  "emits": [
    "datacatalogai.asset.registered",
    "datacatalogai.policy.bound",
    "datacatalogai.asset.deprecated"
  ],
  "consumes": [
    "datalineagetracker.link.updated",
    "dataqualityai.drift.detected",
    "datagovernanceos.policy.updated"
  ],
  "route_prefix": "/api/v1/data-catalog",
  "acceptance_criteria": [
    "All modules implemented end-to-end with tests",
    "OpenAPI and integration-manifest aligned with implementation",
    "No TODO/stub logic in production paths",
    "PR submitted with .jules documentation bundle"
  ]
}