{
  "app_id": "billingai",
  "title": "BillingAI",
  "domain": "Revenue Operations",
  "intent": "Subscription billing orchestration, dunning, and revenue leakage prevention",
  "maturity": {
    "score": 60,
    "tier": "Beta",
    "depth": "Shallow",
    "risks": [
      "no-frontend-tests",
      "no-backend-dockerfile",
      "no-readme"
    ]
  },
  "modules": [
    "plans",
    "invoice-runs",
    "dunning",
    "payments",
    "leakage",
    "tax"
  ],
  "entities": [
    "SubscriptionPlan",
    "InvoiceRun",
    "DunningFlow",
    "PaymentAttempt",
    "RevenueLeakAlert",
    "TaxRule"
  ],
  "emits": [
    "billingai.invoice.generated",
    "billingai.payment.failed",
    "billingai.dunning.completed"
  ],
  "consumes": [
    "usageintelligence.event.received",
    "apimanager.key.generated",
    "notificationhub.channel.registered"
  ],
  "route_prefix": "/api/v1/billing",
  "acceptance_criteria": [
    "All modules implemented end-to-end with tests",
    "OpenAPI and integration-manifest aligned with implementation",
    "No TODO/stub logic in production paths",
    "PR submitted with .jules documentation bundle"
  ]
}