{
  "app_id": "interviewos",
  "title": "InterviewOS",
  "domain": "HR Talent",
  "intent": "Structured interview orchestration and evaluator consistency scoring",
  "maturity": {
    "score": 60,
    "tier": "Beta",
    "depth": "Shallow",
    "risks": [
      "no-frontend-tests",
      "no-backend-dockerfile",
      "no-readme"
    ]
  },
  "modules": [
    "plans",
    "questions",
    "scorecards",
    "evaluations",
    "calibration",
    "decisions"
  ],
  "entities": [
    "InterviewPlan",
    "QuestionBank",
    "Scorecard",
    "EvaluationRecord",
    "CalibrationSignal",
    "DecisionPacket"
  ],
  "emits": [
    "interviewos.score.submitted",
    "interviewos.calibration.required",
    "interviewos.packet.ready"
  ],
  "consumes": [
    "hiresignal.candidate.shortlisted",
    "jobcraftai.posting.published",
    "performancenarrative.review.finalized"
  ],
  "route_prefix": "/api/v1/interviews",
  "acceptance_criteria": [
    "All modules implemented end-to-end with tests",
    "OpenAPI and integration-manifest aligned with implementation",
    "No TODO/stub logic in production paths",
    "PR submitted with .jules documentation bundle"
  ]
}