{
  "app_id": "vendoriq",
  "title": "VendorIQ",
  "domain": "Finance Operations",
  "intent": "Vendor scorecards, SLA tracking, and renewal risk management",
  "maturity": {
    "score": 55,
    "tier": "Alpha",
    "depth": "Shallow",
    "risks": [
      "no-backend-tests",
      "no-frontend-tests",
      "no-backend-dockerfile",
      "no-readme"
    ]
  },
  "modules": [
    "profiles",
    "sla",
    "renewals",
    "risk",
    "contracts",
    "benchmarks"
  ],
  "entities": [
    "VendorProfile",
    "SLAMetric",
    "RenewalSchedule",
    "VendorRisk",
    "ContractTerm",
    "BenchmarkSnapshot"
  ],
