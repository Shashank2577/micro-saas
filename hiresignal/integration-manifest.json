{
  "app": "hiresignal",
  "displayName": "HireSignal",
  "version": "0.0.1",
  "baseUrl": "https://api-hiresignal.YOURDOMAIN.com",
  "emits": [
    {
      "name": "hiresignal.candidate.shortlisted",
      "description": "Emitted when candidate is shortlisted",
      "schema": {}
    },
    {
      "name": "hiresignal.risk.flagged",
      "description": "Emitted when risk is flagged",
      "schema": {}
    },
    {
      "name": "hiresignal.hire.confirmed",
      "description": "Emitted when hire is confirmed",
      "schema": {}
    }
  ],
  "consumes": [
    {
      "name": "jobcraftai.posting.published",
      "description": "Consumed when job is published"
    },
    {
      "name": "interviewos.score.submitted",
      "description": "Consumed when interview score submitted"
    },
    {
      "name": "peopleanalytics.org.signal.updated",
      "description": "Consumed when people analytics signal updated"
    }
  ],
  "capabilities": [],
  "healthEndpoint": "/actuator/health"
}
